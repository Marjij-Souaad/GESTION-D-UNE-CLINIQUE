<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.RendezVousController">

    <Label text="Gestion des Rendez-vous" styleClass="title"/>

    <GridPane hgap="10" vgap="10">

        <Label text="Patient:" GridPane.rowIndex="0"/>
        <ComboBox fx:id="cbPatient" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Date:" GridPane.rowIndex="1"/>
        <DatePicker fx:id="dateRdv" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Heure:" GridPane.rowIndex="2"/>
        <TextField fx:id="txtHeure" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Motif:" GridPane.rowIndex="3"/>
        <TextArea fx:id="txtMotif" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Urgence:" GridPane.rowIndex="4"/>
        <Slider fx:id="sliderUrgence" min="0" max="10"
                GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Nombre séances:" GridPane.rowIndex="5"/>
        <Spinner fx:id="spinnerSeances" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Statut:" GridPane.rowIndex="6"/>
        <ComboBox fx:id="cbStatut" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="10">

        <Button text="Ajouter" onAction="#ajouterRdv"/>
        <Button text="Modifier" onAction="#modifierRdv"/>
        <Button text="Supprimer" onAction="#supprimerRdv"/>

    </HBox>

    <TableView fx:id="tableRdv" prefHeight="200"/>

</VBox>