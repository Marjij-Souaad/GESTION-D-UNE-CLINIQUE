<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.PatientController">

    <Label text="Gestion des Patients" styleClass="title"/>

    <GridPane hgap="10" vgap="10">

        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Prénom:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrenom" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Date naissance:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateNaissance" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Sexe:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>

        <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="1">

            <RadioButton fx:id="rbHomme" text="Homme"/>
            <RadioButton fx:id="rbFemme" text="Femme"/>

        </HBox>

        <Label text="Téléphone:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTelephone" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Adresse:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtAdresse" prefRowCount="3"
                  GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <CheckBox text="Actif" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="10">

        <Button text="Ajouter" onAction="#ajouterPatient"/>
        <Button text="Modifier" onAction="#modifierPatient"/>
        <Button text="Supprimer" onAction="#supprimerPatient"/>
        <Button text="Vider" onAction="#viderChamps"/>

    </HBox>

    <TableView fx:id="tablePatients" prefHeight="200"/>

</VBox>